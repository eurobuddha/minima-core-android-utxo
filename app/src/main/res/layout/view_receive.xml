<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ux_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Minima address"
            android:textColor="@color/ux_subtext"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <ImageView
            android:id="@+id/rcvQr"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@color/white"
            android:padding="8dp" />

        <TextView
            android:id="@+id/rcvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@color/ux_card"
            android:textColor="@color/ux_text"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:gravity="center" />

        <Button
            android:id="@+id/rcvCopy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Copy address"
            android:backgroundTint="@color/ux_accent"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/rcvRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Get address"
            style="?attr/materialButtonOutlinedStyle" />
    </LinearLayout>
</ScrollView>
