<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/ux_card"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <ImageView
        android:id="@+id/balIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="14dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_coin_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/balName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ux_accent"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/balTicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/ux_subtext"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/balTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ux_text"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/balBreakdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ux_subtext"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/balMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ux_subtext"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/balTokenId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ux_subtext"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/balDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ux_subtext"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
