<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ux_bg">

    <!-- Selection bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/ux_card"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/selCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick coins to send"
                android:textColor="@color/ux_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ux_accent"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/toolsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:insetLeft="2dp"
            android:insetRight="2dp"
            android:text="Tools ▾"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/clearBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:insetLeft="2dp"
            android:insetRight="2dp"
            android:text="Clear"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/sendBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:insetLeft="2dp"
            android:insetRight="0dp"
            android:text="Send →"
            android:backgroundTint="@color/ux_accent"
            android:textColor="@color/black" />
    </LinearLayout>

    <TextView
        android:id="@+id/walletStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/walletContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>
</LinearLayout>
