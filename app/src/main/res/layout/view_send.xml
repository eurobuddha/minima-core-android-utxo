<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ux_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- FROM: selected input coins -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FROM — SELECTED COINS"
            android:textColor="@color/ux_subtext" android:textSize="11sp"
            android:letterSpacing="0.1" android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/sendFromList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/ux_card"
            android:padding="12dp" />

        <!-- Recipient -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Recipient address"
            android:textColor="@color/ux_subtext" android:textSize="13sp"
            android:layout_marginTop="18dp" android:layout_marginBottom="5dp" />
        <EditText
            android:id="@+id/sendAddress"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Mx… or 0x…" android:textColorHint="@color/ux_subtext"
            android:textColor="@color/ux_text" android:background="@color/ux_input"
            android:padding="12dp" android:inputType="text" android:maxLines="2"
            android:fontFamily="monospace" android:textSize="13sp" />
        <TextView
            android:id="@+id/sendAddrNote"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="11sp" android:visibility="gone" />

        <!-- Amount + max -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="14dp" android:layout_marginBottom="5dp">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Amount" android:textColor="@color/ux_subtext" android:textSize="13sp" />
            <TextView
                android:id="@+id/maxBtn"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MAX" android:textColor="@color/ux_accent" android:textSize="11sp"
                android:letterSpacing="0.1" android:padding="4dp" />
        </LinearLayout>
        <EditText
            android:id="@+id/sendAmount"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0.0" android:textColorHint="@color/ux_subtext"
            android:textColor="@color/ux_text" android:background="@color/ux_input"
            android:padding="12dp" android:inputType="numberDecimal"
            android:fontFamily="monospace" android:textSize="13sp" />
        <TextView
            android:id="@+id/sendAmountNote"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="11sp" android:visibility="gone" />

        <!-- Change + next -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="14dp" android:layout_marginBottom="5dp">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Change goes to" android:textColor="@color/ux_subtext" android:textSize="13sp" />
            <TextView
                android:id="@+id/nextBtn"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NEXT" android:textColor="@color/ux_accent" android:textSize="11sp"
                android:letterSpacing="0.1" android:padding="4dp" />
        </LinearLayout>
        <EditText
            android:id="@+id/sendChange"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Mx…" android:textColorHint="@color/ux_subtext"
            android:textColor="@color/ux_text" android:background="@color/ux_input"
            android:padding="12dp" android:inputType="text" android:maxLines="2"
            android:fontFamily="monospace" android:textSize="13sp" />
        <TextView
            android:id="@+id/sendChangeNote"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="11sp" android:visibility="gone" />

        <!-- Burn -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Burn (Minima only — optional)"
            android:textColor="@color/ux_subtext" android:textSize="13sp"
            android:layout_marginTop="14dp" android:layout_marginBottom="5dp" />
        <EditText
            android:id="@+id/sendBurn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="0" android:textColorHint="@color/ux_subtext"
            android:textColor="@color/ux_text" android:background="@color/ux_input"
            android:padding="12dp" android:inputType="numberDecimal"
            android:fontFamily="monospace" android:textSize="13sp" />
        <TextView
            android:id="@+id/sendBurnNote"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textSize="11sp" android:visibility="gone" />

        <Button
            android:id="@+id/previewBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:text="Preview →"
            android:backgroundTint="@color/ux_accent" android:textColor="@color/black" />

        <TextView
            android:id="@+id/sendStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp" android:padding="10dp"
            android:textSize="13sp" android:gravity="center" android:visibility="gone" />
    </LinearLayout>
</ScrollView>
